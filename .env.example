# Required
ANTHROPIC_API_KEY=your_key

# Solana RPC — use Helius for production (free tier: 100 req/s)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Email verification — pick one:
# Option A: Resend (recommended, free tier) — https://resend.com
RESEND_API_KEY=
FROM_EMAIL=SANO <noreply@yourdomain.com>
# Option B: Privy server auth — https://dashboard.privy.io
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Fiat on-ramp — https://dashboard.moonpay.com
MOONPAY_API_KEY=

# Flights + hotels — https://duffel.com
DUFFEL_API_TOKEN=

# Amazon product search — https://www.scaleserp.com
SEARCH_API_KEY=

PORT=3000
