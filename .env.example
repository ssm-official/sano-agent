# Required
ANTHROPIC_API_KEY=your_anthropic_api_key

# Privy (wallet auth) — https://dashboard.privy.io
PRIVY_APP_ID=your_privy_app_id

# Solana RPC (default: public mainnet — use Helius/Quicknode for production)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Amazon product search — https://www.scaleserp.com
SEARCH_API_KEY=

# Optional: Flights & hotels — https://developers.amadeus.com (free tier)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

PORT=3000
