# Required
ANTHROPIC_API_KEY=your_key

# Solana RPC — use Helius for production (free tier: 100 req/s)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Email verification (recommended: Resend)
RESEND_API_KEY=
FROM_EMAIL=SANO <noreply@yourdomain.com>

# Bitrefill — autonomous shopping via gift cards
# Get key at https://www.bitrefill.com/account/developers
BITREFILL_API_KEY=

# Product search (all stores) — https://www.scaleserp.com
SEARCH_API_KEY=

# Optional: persist user data across deploys
# Add a Railway Volume mounted at /data and set:
# DATA_DIR=/data

# Optional: fiat on-ramp
MOONPAY_API_KEY=

PORT=3000
